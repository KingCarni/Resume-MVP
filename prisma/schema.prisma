generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastDailyBonusAt DateTime?

  // Donation requests submitted by this user (asking for help)
  donationRequests DonationRequest[]

  accounts      Account[]
  creditsLedger CreditsLedger[]
  documents     Document[]
  events        Event[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CreditsLedger {
  id        String   @id @default(cuid())
  userId    String
  delta     Int
  reason    String
  ref       String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ref])
  @@index([userId, createdAt])
}

model Document {
  id        String       @id @default(cuid())
  userId    String
  type      DocumentType
  title     String?
  template  String?
  html      String?
  text      String?
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Event {
  id        String    @id @default(cuid())
  userId    String
  type      EventType
  metaJson  Json?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

enum DocumentType {
  resume
  cover_letter
}

enum EventType {
  login
  analyze
  rewrite_bullet
  rewrite_batch
  resume_pdf
  cover_letter
  purchase
}

enum DonationRequestStatus {
  pending
  approved
  rejected
  fulfilled
}

model DonationRequest {
  id               String @id @default(cuid())
  userId           String
  requestedCredits Int
  reason           String

  // Workflow: user submits -> admin approves/rejects -> later admin fulfills (credits transfer)
  status DonationRequestStatus @default(pending)

  // Admin review (approval/rejection) – does NOT move credits
  reviewNote      String?
  reviewedAt      DateTime?
  reviewedByEmail String? // simplest: store your admin email used during action

  // Fulfillment – this is where credits are actually granted
  fulfilledAt      DateTime?
  fulfilledByEmail String?
  fulfillRef       String? // idempotency key for the fulfill operation (set once)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Prevent double-fulfill: only one request can have a given fulfillRef
  @@unique([fulfillRef])
  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  // Helpful admin screens
  @@index([reviewedAt])
  @@index([fulfilledAt])
}
