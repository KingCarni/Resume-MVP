generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastDailyBonusAt DateTime?

  // Donation requests submitted by this user (asking for help)
  donationRequests DonationRequest[]

  accounts      Account[]
  creditsLedger CreditsLedger[]
  documents     Document[]
  events        Event[]
  sessions      Session[]

  // AI Job Match
  resumeProfiles  ResumeProfile[]
  jobMatches      JobMatch[]
  jobMatchWarmups JobMatchWarmup[]
  savedJobs       SavedJob[]
  hiddenJobs      HiddenJob[]
  jobApplications JobApplication[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CreditsLedger {
  id        String   @id @default(cuid())
  userId    String
  delta     Int
  reason    String
  ref       String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ref])
  @@index([userId, createdAt])
}

model Document {
  id                  String       @id @default(cuid())
  userId              String
  type                DocumentType
  title               String?
  template            String?
  html                String?
  text                String?
  structuredData      Json?
  sourceFileName      String?
  sourceMimeType      String?
  sourceFileExtension String?
  sourceKind          String?
  createdAt           DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // AI Job Match
  resumeProfiles ResumeProfile[]

  @@index([userId, createdAt])
}

model Event {
  id        String    @id @default(cuid())
  userId    String
  type      EventType
  metaJson  Json?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

enum DocumentType {
  resume
  cover_letter
}

enum EventType {
  login
  analyze
  rewrite_bullet
  rewrite_batch
  resume_pdf
  cover_letter
  purchase
}

enum DonationRequestStatus {
  pending
  approved
  rejected
  fulfilled
}

model DonationRequest {
  id               String @id @default(cuid())
  userId           String
  requestedCredits Int
  reason           String

  // Workflow: user submits -> admin approves/rejects -> later admin fulfills (credits transfer)
  status DonationRequestStatus @default(pending)

  // Admin review (approval/rejection) – does NOT move credits
  reviewNote      String?
  reviewedAt      DateTime?
  reviewedByEmail String? // simplest: store your admin email used during action

  // Fulfillment – this is where credits are actually granted
  fulfilledAt      DateTime?
  fulfilledByEmail String?
  fulfillRef       String? // idempotency key for the fulfill operation (set once)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Prevent double-fulfill: only one request can have a given fulfillRef
  @@unique([fulfillRef])
  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  // Helpful admin screens
  @@index([reviewedAt])
  @@index([fulfilledAt])
}

enum JobSourceKind {
  manual
  ats_feed
  api
}

enum JobImportAdapter {
  greenhouse
  lever
  ashby
}

enum RemoteType {
  remote
  hybrid
  onsite
  unknown
}

enum EmploymentType {
  full_time
  part_time
  contract
  temporary
  internship
  freelance
  other
  unknown
}

enum SeniorityLevel {
  entry
  junior
  mid
  senior
  lead
  staff
  principal
  manager
  director
  executive
  unknown
}

enum JobStatus {
  active
  closed
  expired
}

enum JobApplicationStatus {
  applied
  interview
  offer
  rejected
  archived
}

model ResumeProfile {
  id               String         @id @default(cuid())
  userId           String
  sourceDocumentId String?
  title            String?
  rawText          String?
  normalizedSkills Json?
  normalizedTitles Json?
  seniority        SeniorityLevel @default(unknown)
  yearsExperience  Int?
  industries       Json?
  certifications   Json?
  keywords         Json?
  summary          String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceDocument Document?       @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  jobMatches     JobMatch[]
  jobMatchWarmup JobMatchWarmup?

  @@index([userId, createdAt])
  @@index([userId, updatedAt])
  @@index([sourceDocumentId])
}

model JobSource {
  id        String        @id @default(cuid())
  slug      String        @unique
  name      String
  kind      JobSourceKind @default(manual)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  jobs Job[]

  @@index([kind, isActive])
}

model JobImportSource {
  id              String           @id @default(cuid())
  adapter         JobImportAdapter
  tokenOrSite     String
  displayName     String
  companyOverride String?
  isActive        Boolean          @default(true)
  refreshHours    Int              @default(24)
  lastRunAt       DateTime?
  lastSuccessAt   DateTime?
  lastErrorAt     DateTime?
  lastError       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([adapter, tokenOrSite])
  @@index([isActive])
  @@index([adapter])
  @@index([lastSuccessAt])
}

model Job {
  id                   String         @id @default(cuid())
  sourceId             String
  externalId           String?
  company              String
  companyNormalized    String?
  title                String
  titleNormalized      String?
  location             String?
  locationNormalized   String?
  remoteType           RemoteType     @default(unknown)
  employmentType       EmploymentType @default(unknown)
  seniority            SeniorityLevel @default(unknown)
  salaryMin            Int?
  salaryMax            Int?
  salaryCurrency       String?
  description          String
  requirementsText     String?
  responsibilitiesText String?
  skills               Json?
  keywords             Json?
  postedAt             DateTime?
  applyUrl             String?
  sourceUrl            String?
  rawPayload           Json?
  status               JobStatus      @default(active)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  source       JobSource       @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  matches      JobMatch[]
  savedBy      SavedJob[]
  hiddenBy     HiddenJob[]
  applications JobApplication[]

  @@unique([sourceId, externalId])
  @@index([status, createdAt])
  @@index([status, postedAt])
  @@index([companyNormalized])
  @@index([titleNormalized])
  @@index([locationNormalized])
  @@index([remoteType, status])
  @@index([seniority, status])
  @@index([sourceId, status])
}

model JobMatch {
  id               String   @id @default(cuid())
  userId           String
  resumeProfileId  String
  jobId            String
  totalScore       Int
  titleScore       Int
  skillScore       Int
  seniorityScore   Int
  locationScore    Int
  keywordScore     Int
  explanationShort String?
  missingSkills    Json?
  matchingSkills   Json?
  computedAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeProfile ResumeProfile @relation(fields: [resumeProfileId], references: [id], onDelete: Cascade)
  job           Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([resumeProfileId, jobId])
  @@index([userId, createdAt])
  @@index([jobId, totalScore])
  @@index([resumeProfileId, computedAt])
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId, createdAt])
  @@index([jobId])
}

model HiddenJob {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId, createdAt])
  @@index([jobId])
}

model JobApplication {
  id        String               @id @default(cuid())
  userId    String
  jobId     String
  status    JobApplicationStatus @default(applied)
  appliedAt DateTime             @default(now())
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId, status, updatedAt])
  @@index([jobId])
}

enum JobMatchWarmupStatus {
  pending
  running
  ready
  failed
  stale
}

model JobMatchWarmup {
  id                  String               @id @default(cuid())
  userId              String
  resumeProfileId     String               @unique
  status              JobMatchWarmupStatus @default(pending)
  totalCandidateCount Int                  @default(0)
  processedCount      Int                  @default(0)
  lastProcessedJobId  String?
  lastError           String?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeProfile ResumeProfile @relation(fields: [resumeProfileId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, updatedAt])
}
